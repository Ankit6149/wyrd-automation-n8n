    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst source = (body.source || 'direct').trim();\nconst email  = body.email;\nconst name   = body.name   || 'there';\nconst message = body.message || '';\n\nlet leadType;\nif (['google_ads', 'facebook_ads', 'instagram_ads'].includes(source)) {\n  leadType = 'Paid';\n} else {\n  leadType = 'Organic';\n}\n\nconst leadScore = message.length > 100 ? 'hot' : message.length > 30 ? 'warm' : 'cold';\n\nreturn [{\n  json: {\n    email,\n    name,\n    message,\n    source,\n    leadType,\n    leadScore,\n    receivedAt: new Date().toISOString()\n  }\n}];"
      },
