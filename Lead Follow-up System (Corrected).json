    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst followUpTime = new Date(Date.now() + (24 * 60)).toISOString();\n\nreturn [{\n  json: {\n    ...item,\n    followUpTime,\n    followUpSubject: 'Just checking in 👋',\n    followUpBody: `Hi ${item.name}, just wanted to follow up on your enquiry. Let us know if you have any questions — we'd love to help.`\n  }\n}];"
      },
