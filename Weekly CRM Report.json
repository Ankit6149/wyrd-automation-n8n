      "name": "Manual Filtering Deals"
    },
    {
      "parameters": {
        "jsCode": "const start = new Date($node[\"Compute Week Range\"].json.startOfWeek);\n\nreturn items.filter(item => {\n  const updated =\n    item.json.updatedAt ||\n    item.json.updated_at;\n\n  if (!updated) return false;\n\n  const updatedDate = new Date(updated);\n  if (isNaN(updatedDate)) return false;\n\n  return updatedDate >= start;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        384
      ],
      "id": "7a816b0e-deae-40fb-93bc-a7a492fa4a12",
      "name": "Manual Filtering Tasks"
    },
    {
      "parameters": {
        "jsCode": "const start = new Date($node[\"Compute Week Range\"].json.startOfWeek);\n\nreturn items.filter(item => {\n  const date =\n    item.json.createdAt ||\n    item.json.date;\n\n  if (!date) return false;\n\n  const parsed = new Date(date);\n  if (isNaN(parsed)) return false;\n\n  return parsed >= start;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        576
      ],
      "id": "3d755de9-fad1-4927-84d3-67a988f3677e",
      "name": "Manual Filtering Activities"
    },
    {
      "parameters": {
        "jsCode": "const start = new Date($node[\"Compute Week Range\"].json.startOfWeek);\n\nlet summary = {\n  newLeads: [],\n  dealsMoved: [],\n  completedTasks: [],\n  activities: []\n};\n\nfor (const item of items) {\n  const data = item.json;\n  const type = data.type;\n\n  const dateField =\n    data.createdAt ||\n    data.created_at ||\n    data.updatedAt ||\n    data.updated_at ||\n    data.date;\n\n  if (!dateField) continue;\n\n  const parsedDate = new Date(dateField);\n  if (isNaN(parsedDate)) continue;\n  if (parsedDate < start) continue;\n\n  if (type === \"lead\") {\n    summary.newLeads.push(data);\n  }\n\n  if (type === \"deal\") {\n    summary.dealsMoved.push(data);\n  }\n\n  if (type === \"task\" && data.status === \"completed\") {\n    summary.completedTasks.push(data);\n  }\n\n  if (type === \"activity\") {\n    summary.activities.push(data);\n  }\n}\n\n// ADD COUNTS\nsummary.counts = {\n  leads: summary.newLeads.length,\n  deals: summary.dealsMoved.length,\n  tasks: summary.completedTasks.length,\n  activities: summary.activities.length\n};\n\nreturn [{ json: summary }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        736,
        288
      ],
      "id": "db5b63ea-cc2d-4b07-8759-6f167926659d",
      "name": "Process Weekly Summary"
    },
    {
      "parameters": {
        "jsCode": "const summary = items[0].json;\n\nlet report = `\nWEEKLY CRM SUMMARY\n\nNew Leads: ${summary.counts.leads}\nDeals Moved: ${summary.counts.deals}\nTasks Completed: ${summary.counts.tasks}\nActivities Logged: ${summary.counts.activities}\n\n--------------------------\n\nLEADS:\n${summary.newLeads.map(l => `- ${l.name || l.email}`).join(\"\\n\")}\n\n--------------------------\n\nDEALS:\n${summary.dealsMoved.map(d => `- ${d.title || d.name}`).join(\"\\n\")}\n\n--------------------------\n\nTASKS COMPLETED:\n${summary.completedTasks.map(t => `- ${t.title}`).join(\"\\n\")}\n\n--------------------------\n\nACTIVITIES:\n${summary.activities.map(a => `- ${a.type || a.description}`).join(\"\\n\")}\n`;\n\nreturn [{ json: { report } }];"
      },
      "type": "n8n-nodes-base.code",
