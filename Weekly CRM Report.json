    {
      "parameters": {
        "jsCode": "const start = new Date($node[\"Compute Week Range\"].json.startOfWeek);\n\nreturn items.filter(item => {\n  const created =\n    item.json.createdAt ||\n    item.json.created_at ||\n    item.json.date;\n\n  if (!created) return false;\n\n  const createdDate = new Date(created);\n  if (isNaN(createdDate)) return false;\n\n  return createdDate >= start;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ],
      "id": "b307d287-8a20-46c3-90e7-7104db7df5f3",
      "name": "Manual Filtering Leads"
    },
    {
      "parameters": {
        "jsCode": "const start = new Date($node[\"Compute Week Range\"].json.startOfWeek);\n\nreturn items.filter(item => {\n  const updated =\n    item.json.updatedAt ||\n    item.json.updated_at;\n\n  if (!updated) return false;\n\n  const updatedDate = new Date(updated);\n  if (isNaN(updatedDate)) return false;\n\n  return updatedDate >= start;\n});"
      },
      "type": "n8n-nodes-base.code",
